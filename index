function doPost(e) {
  try {
    var data = JSON.parse(e.postData.contents);
    var recipients = data.recipients || [];
    var asunto = data.asunto || '(sin asunto)';
    var cuerpo = data.cuerpo || '';

    var enviados = 0;
    var errores = [];

    for (var i = 0; i < recipients.length; i++) {
      var r = recipients[i];
      if (!r.email) continue;
      try {
        // Personaliza el mensaje con el nombre del paciente
        var mensajePersonalizado = 'Estimado/a ' + (r.nombre || '') + ',\n\n' + cuerpo + '\n\nFarmacia';

        GmailApp.sendEmail(r.email, asunto, mensajePersonalizado, {
          name: 'Farmacia' // Aparece como nombre del remitente
        });
        enviados++;

        // Pausa breve para no saturar el límite de envíos de Gmail
        Utilities.sleep(300);
      } catch (err) {
        errores.push(r.email + ': ' + err.message);
      }
    }

    return ContentService.createTextOutput(JSON.stringify({
      ok: true,
      enviados: enviados,
      errores: errores
    })).setMimeType(ContentService.MimeType.JSON);

  } catch (err) {
    return ContentService.createTextOutput(JSON.stringify({
      ok: false,
      error: err.message
    })).setMimeType(ContentService.MimeType.JSON);
  }
}
